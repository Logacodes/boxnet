def checkfile():
    if not SESFILE.exists():
        return None
    try:
        with open(SESFILE, "r") as f:
            sesdata = json.load(f)
        deline = datetime.fromisoformat(sesdata["expiry"])
        curtime = datetime.now(timezone.utc)
        if curtime > deline:
            print(f"SESSION STATUS: EXPIRED.\nRedirecting to home ...")
            return userexists()
    
        else:
            print(f"SESSION STATUS: ACTIVE.")
            boxid = sesdata.get("boxid")
            return boxt(boxid)
        
        
    except Exception:
        print("Error with file reading or analysis.")
        return None
    
def save_ses(boxid, email):
    crntime = datetime.now(timezone.utc)
    expiry = crntime + timedelta(days=7)
    data = ({
        "boxid": boxid,
        "email": email,
        "logtime": crntime.isoformat(),
        "expiry": expiry.isoformat()
    })

    with open(SESFILE, "w") as f:
        json.dump(data, f, indent=4)

