def is_email_valid(email):
    try:
        v = validate_email(email, check_deliverability=False)
        email = v.normalized
        return True, email
    except EmailNotValidError as e:
        print(str(e))
        return False, None
def strpss(password):
    clength = len(password) >= 8
    cupcase = any(ch.isupper() for ch in password)
    cnumber = any(ch.isdigit() for ch in password)

    if clength and cupcase and cnumber:
        return True
    else:
        if not clength: print("Weak: Use 8+ characters.")
        if not cupcase: print("Weak: Include an uppercase letter.")
        if not cnumber: print("Weak: Include a number.")
        return False
