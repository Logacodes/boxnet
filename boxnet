def is_email_valid(email):
    try:
        v = validate_email(email, check_deliverability=False)
        email = v.normalized
        return True, email
    except EmailNotValidError as e:
        print(str(e))
        return False, None
def strpss(password):
    clength = len(password) >= 8
    cupcase = any(ch.isupper() for ch in password)
    cnumber = any(ch.isdigit() for ch in password)

    if clength and cupcase and cnumber:
        return True
    else:
        if not clength: print("Weak: Use 8+ characters.")
        if not cupcase: print("Weak: Include an uppercase letter.")
        if not cnumber: print("Weak: Include a number.")
        return False
def login():
    print("="*30)
    print("      BOXNET LOGIN")
    print("="*30)
    
    while True:
        identifier = input("Enter your email or BoxID: ")
        password = pwinput.pwinput("Enter your password: ", mask="*")
        
        is_email, normalized_email = is_email_valid(identifier)
        
        if is_email:
            users = db.child("users").get().val()
            user_found = None
            if users:
                for boxid, data in users.items():
                    if data.get("email") == normalized_email:
                        user_found = data
                        user_found["boxid"] = boxid
                        break
            if not user_found:
                print("Email not found. Please try again.")
                continue
        else:
            user_found = db.child("users").child(identifier).get().val()
            if not user_found:
                print("BoxID not found. Please try again.")
                continue
            user_found["boxid"] = identifier
        
        if user_found.get("password") == hashlib.sha256(password.encode()).hexdigest():
            try:
                user = auth.sign_in_with_email_and_password(user_found["email"], password)
                print("Login successful.")
                return user_found
            except Exception as e:
                print(f"Authentication failed: {e}")
                continue
        else:
            print("Invalid password. Please try again.")
            return login()

