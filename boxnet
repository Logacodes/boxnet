def hash_existing_data():
    users = db.child("users").get().val()
    if users:
        for boxid, data in users.items():
            updated = False
            if "password" in data and not data["password"].startswith(("sha256:", "$2b$", "$2a$")):
                data["password"] = hashlib.sha256(data["password"].encode()).hexdigest()
                updated = True
            if updated:
                db.child("users").child(boxid).update(data)
                print(f"Hashed data for user {boxid}")
    print("Existing data hashing completed.")
